# North Lantern Group - Website Environment Variables
# Copy this file to .env.local and fill in the values
# All 4 variables are required for the contact form to function

# Resend API Key - Sends contact form emails
# Get yours at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ZeroBounce API Key - Validates email addresses before sending
# Get yours at https://zerobounce.net
ZEROBOUNCE_API_KEY=your_zerobounce_api_key_here

# Google reCAPTCHA v3 - Spam protection on contact form
# Get yours at https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
