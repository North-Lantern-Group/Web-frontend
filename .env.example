# North Lantern Group - Website Environment Variables
# Copy this file to .env.local and fill in the values
# The first 4 variables are required for the contact form email path.
# Lead backup variables are optional until the Google Sheet/App Script
# integration is deployed.

# Resend API Key - Sends contact form emails
# Get yours at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ZeroBounce API Key - Validates email addresses before sending
# Get yours at https://zerobounce.net
ZEROBOUNCE_API_KEY=your_zerobounce_api_key_here

# Google reCAPTCHA v3 - Spam protection on contact form
# Get yours at https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Upstash Redis - Contact form rate limiting
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here
CONTACT_RATE_LIMIT_ENABLED=true

# Optional Google Sheets lead backup via Google Apps Script Web App
# Keep disabled until the Apps Script endpoint and HMAC secret are configured.
LEAD_BACKUP_ENABLED=false
LEAD_BACKUP_WEB_APP_URL=https://script.google.com/macros/s/your_deployment_id/exec
LEAD_BACKUP_HMAC_SECRET=generate_a_long_random_secret
LEAD_BACKUP_TIMEOUT_MS=4000
